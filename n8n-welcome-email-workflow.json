    {
      "parameters": {
        "fromEmail": "andrea@yourdomain.com",
        "toEmail": "={{ $json.email }}",
        "subject": "Thank you for subscribing! 🎨",
        "contentType": "html",
        "message": "<div style=\"font-family: 'Georgia', serif; max-width: 600px; margin: 0 auto; background-color: #FAF6F1; padding: 40px; border-radius: 12px;\">\n  <div style=\"text-align: center; margin-bottom: 30px;\">\n    <h1 style=\"color: #C17B5E; font-size: 28px; margin: 0;\">Welcome! 🎨</h1>\n  </div>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Dear {{ $json.name ? $json.name : 'Subscriber' }},</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">I'm so glad you've joined my community! 💛</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">In my newsletters, I write about <strong style=\"color: #C17B5E;\">design thinking</strong>, <strong style=\"color: #8FAE8B;\">art therapy</strong>, <strong style=\"color: #D4A843;\">digital transformation</strong>, and <strong>personal growth</strong> — exploring where business, technology, and creativity meet.</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">What you can expect:</p>\n  <ul style=\"color: #3D3229; font-size: 16px; line-height: 2;\">\n    <li>🧠 Insights on design thinking and innovation</li>\n    <li>🎨 Inspiration on art therapy and mental well-being</li>\n    <li>💡 Behind-the-scenes of my digital transformation projects</li>\n    <li>📚 Book recommendations and personal growth tips</li>\n  </ul>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">If you have any questions, feel free to reply to this email!</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Warm regards,<br><strong style=\"color: #C17B5E;\">Andrea Molnár</strong></p>\n  \n  <hr style=\"border: none; border-top: 1px solid #E8DDD4; margin: 30px 0;\">\n  <p style=\"color: #9B8E82; font-size: 12px; text-align: center;\">Design, Transformation & Art Therapy</p>\n</div>"
      },
