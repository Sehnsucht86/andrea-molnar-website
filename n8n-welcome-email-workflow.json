    {
      "parameters": {
        "fromEmail": "andrea@yourdomain.com",
        "toEmail": "={{ $json.email }}",
        "subject": "Köszönöm a feliratkozást! 🎨",
        "contentType": "html",
        "message": "<div style=\"font-family: 'Georgia', serif; max-width: 600px; margin: 0 auto; background-color: #FAF6F1; padding: 40px; border-radius: 12px;\">\n  <div style=\"text-align: center; margin-bottom: 30px;\">\n    <h1 style=\"color: #C17B5E; font-size: 28px; margin: 0;\">Üdvözöllek! 🎨</h1>\n  </div>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Kedves {{ $json.name ? $json.name : 'Feliratkozó' }},</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Nagyon örülök, hogy csatlakoztál a közösségemhez! 💛</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">A hírleveleimben a <strong style=\"color: #C17B5E;\">design thinking</strong>, az <strong style=\"color: #8FAE8B;\">art terápia</strong>, a <strong style=\"color: #D4A843;\">digitális transzformáció</strong> és a <strong>személyes fejlődés</strong> témáiról írok — arról, hogyan találkozik az üzlet, a technológia és a kreativitás.</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Amit várhatsz tőlem:</p>\n  <ul style=\"color: #3D3229; font-size: 16px; line-height: 2;\">\n    <li>🧠 Gondolatok a design thinking és az innováció világából</li>\n    <li>🎨 Inspiráció az art terápia és a mentális jóllét témájában</li>\n    <li>💡 Betekintés a digitális transzformáció projektjeimbe</li>\n    <li>📚 Könyvajánlók és személyes fejlődési tippek</li>\n  </ul>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Ha bármilyen kérdésed van, nyugodtan válaszolj erre az emailre!</p>\n  \n  <p style=\"color: #3D3229; font-size: 16px; line-height: 1.8;\">Meleg üdvözlettel,<br><strong style=\"color: #C17B5E;\">Andrea Molnár</strong></p>\n  \n  <hr style=\"border: none; border-top: 1px solid #E8DDD4; margin: 30px 0;\">\n  <p style=\"color: #9B8E82; font-size: 12px; text-align: center;\">Design, Transzformáció & Art Terápia</p>\n</div>"
      },
      "id": "send-email-hu",
      "name": "Send Welcome Email (HU)",
      "type": "n8n-nodes-base.sendGrid",
      "typeVersion": 1,
